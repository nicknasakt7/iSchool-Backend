// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: npx create-db

generator client {
  provider     = "prisma-client"
  output       = "../src/database/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  PARENTS
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum Trend {
  IMPROVED
  DECLINED
  STABLE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum PaymentMethod {
  STRIPE
  TRANSFER
}

enum EnrollmentStatus {
  ACTIVE
  PROMOTED
  REPEATED
  TRANSFERRED
}

enum LeadStatus {
  WAITING
  CONTACTED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  gender   Gender
  role     Role

  parent  Parent?
  teacher Teacher?

  profileImageUrl      String? @map("profile_image_url")
  profileImagePublicId String? @map("profile_image_public_id")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Parent {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  firstName String
  lastName  String

  tel    String?
  lineId String?

  students Student[]
  payments Payment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Teacher {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  firstName String
  lastName  String

  homeroomClassId String?
  homeroomClass   Classroom? @relation("HomeroomClass", fields: [homeroomClassId], references: [id])

  subjects SubjectAssignment[]

  comments TeacherComment[]
  analyses AIStudentAnalysis[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Grade {
  id    String @id @default(uuid())
  name  String @unique
  level Int    @unique

  classrooms Classroom[]

  createdAt          DateTime                   @default(now())
  studentEnrollments StudentEnrollmentHistory[]
  students           Student[]
  updatedAt          DateTime                   @updatedAt
  isActive           Boolean                    @default(true)
  interestedLeads    InterestedLead[]
}

model Classroom {
  id   String @id @default(uuid())
  name String @unique

  gradeId String
  grade   Grade  @relation(fields: [gradeId], references: [id])

  students           Student[]
  homeroomTeacher    Teacher[]                  @relation("HomeroomClass")
  subjectAssignments SubjectAssignment[]
  studentEnrollments StudentEnrollmentHistory[]

  createdAt DateTime @default(now())
  isActive  Boolean  @default(true)

  @@unique([name, gradeId])
}

model Student {
  id          String @id @default(uuid())
  studentCode String @unique @default(uuid())

  firstName String
  lastName  String
  nickName  String
  dob       DateTime
  gender    Gender

  healthNote String?
  favorite   String?

  gradeId String
  grade   Grade  @relation(fields: [gradeId], references: [id])

  classId   String?
  classroom Classroom? @relation(fields: [classId], references: [id])

  parentId String?
  parent   Parent? @relation(fields: [parentId], references: [id])

  attendances Attendance[]
  scores      Score[]
  comments    TeacherComment[]
  analyses    AIStudentAnalysis[]
  payments    Payment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  studentEnrollments StudentEnrollmentHistory[]
}

model StudentEnrollmentHistory {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  gradeId String
  grade   Grade  @relation(fields: [gradeId], references: [id])

  classroomId String?
  classroom   Classroom? @relation(fields: [classroomId], references: [id])

  year Int
  term Int

  status EnrollmentStatus

  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime @default(now())

  @@unique([studentId, year, term])
}

model Subject {
  id   String @id @default(uuid())
  name String

  assignments SubjectAssignment[]
  configs     AssessmentConfig[]
  scores      Score[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  teacherComments TeacherComment[]
}

model SubjectAssignment {
  id String @id @default(uuid())

  teacherId String
  subjectId String
  classId   String

  teacher   Teacher   @relation(fields: [teacherId], references: [id])
  subject   Subject   @relation(fields: [subjectId], references: [id])
  classroom Classroom @relation(fields: [classId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([teacherId, subjectId, classId])
}

// ตอนสร้างคะแนน
model AssessmentConfig {
  id String @id @default(uuid())

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  name     String
  maxScore Int
  order    Int
  year     Int
  term     Int

  scoreItems ScoreItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// คะแนนที่รวมแล้วกับเกรดของวิชา
model Score {
  id String @id @default(uuid())

  studentId String
  subjectId String

  student Student @relation(fields: [studentId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  term       Int
  year       Int
  totalScore Float       @default(0)
  items      ScoreItem[]

  subjectGrade Float @default(0) @map("subject_grade")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, subjectId, term, year])
}

// คะแนนที่กรอกให้นักเรียน 
model ScoreItem {
  id String @id @default(uuid())

  scoreId  String
  configId String

  score  Score            @relation(fields: [scoreId], references: [id])
  config AssessmentConfig @relation(fields: [configId], references: [id])

  value Float @default(0)

  createAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scoreId, configId])
}

model Attendance {
  id        String  @id @default(uuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  date   DateTime
  status AttendanceStatus

  createAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
}

model TeacherComment {
  id String @id @default(uuid())

  studentId String
  teacherId String
  subjectId String

  student Student @relation(fields: [studentId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  content String

  term Int
  year Int

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([studentId, subjectId, term, year])
}

model AIStudentAnalysis {
  id String @id @default(uuid())

  studentId String
  teacherId String

  student Student @relation(fields: [studentId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  summary    String
  strength   String
  weakness   String
  suggestion String

  trend     Trend
  riskLevel RiskLevel

  term Int
  year Int

  isLocked    Boolean  @default(false)
  generatedAt DateTime @default(now())

  createdAt DateTime @default(now())

  @@unique([studentId, term, year])
  @@index([studentId, term, year])
}

model Payment {
  id String @id @default(uuid())

  studentId String
  parentId  String

  student Student @relation(fields: [studentId], references: [id])
  parent  Parent  @relation(fields: [parentId], references: [id])

  term Int
  year Int

  amount Int

  method         PaymentMethod? // STRIPE / TRANSFER
  transactionRef String? // Stripe id (optional)

  qrCodeUrl String?

  isPaid Boolean @default(false) // ใช้กด confirm

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([studentId, term, year])
}

model Notice {
  id        String    @id @default(uuid())
  title     String
  content   String
  date      DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model CalendarImage {
  id       String @id @default(uuid())
  title    String
  imageUrl String

  createdAt DateTime @default(now())
}

model InterestedLead {
  id String @id @default(uuid())

  // Parent
  parentFirstName String
  parentLastName  String
  email           String
  tel             String?

  // Student
  studentFirstName String
  studentLastName  String

  gradeId String
  grade   Grade  @relation(fields: [gradeId], references: [id])

  // Status เอาไว้ track funnel
  status LeadStatus @default(WAITING)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model ParentInvite {
  id String @id @default(uuid())

  email String
  token String @unique

  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())
}
